          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Global persistent counter (resets when test restarts)
def key = &apos;global.username.counter&apos;
int n = (props.get(key) ?: &apos;0&apos;) as int
n++
props.put(key, String.valueOf(n))

// Generate valid username (alphanumeric, starting with letter)
def username = &quot;user${n}&quot;
vars.put(&apos;customer.username&apos;, username)

// Output the generated username
log.info(&quot;Generated username: ${username}&quot;)</stringProp>
          </JSR223PreProcessor>
