          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Natural looking usernames
def firstNames = [&apos;john&apos;, &apos;sarah&apos;, &apos;mike&apos;, &apos;emma&apos;, &apos;david&apos;, &apos;lisa&apos;, &apos;tom&apos;, &apos;anna&apos;, &apos;james&apos;, &apos;kate&apos;]
def lastNames = [&apos;smith&apos;, &apos;jones&apos;, &apos;brown&apos;, &apos;wilson&apos;, &apos;davis&apos;, &apos;miller&apos;, &apos;moore&apos;, &apos;taylor&apos;, &apos;anderson&apos;, &apos;thomas&apos;]

def random = new Random()
def firstName = firstNames[random.nextInt(firstNames.size())]
def lastName = lastNames[random.nextInt(lastNames.size())]
def number = random.nextInt(9999)

// Generate natural username
def username = &quot;${firstName}${lastName}${number}&quot;
vars.put(&apos;customer.username&apos;, username)

log.info(&quot;Generated username: ${username}&quot;)
// Output examples: johnsmith847, sarahjones23, mikebrown5621</stringProp>
          </JSR223PreProcessor>
